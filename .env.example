# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API Key (required for Investigator and Healer agents)
OPENAI_API_KEY=sk-...

# LLM model to use
LLM_MODEL=gpt-4o-mini

# Redis connection (default: local Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./immune_memory.db

# Threat detection thresholds
ANOMALY_THRESHOLD=2.5          # z-score above which traffic is anomalous
BRUTE_FORCE_THRESHOLD=10       # failed logins per minute before alerting
PORT_SCAN_THRESHOLD=20         # unique paths per 10s before alerting
RATE_LIMIT_THRESHOLD=100       # requests per minute per IP before alerting

# Agent behavior
SENTINEL_BLOCK_DURATION=3600   # seconds to block a suspicious IP
SIMULATE_ACTIONS=true          # set to false to execute real OS-level actions

# Simulation settings
SIMULATION_TARGET_PORT=8001
SIMULATION_ATTACK_INTERVAL=15  # seconds between simulated attacks

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/immune_system.log
